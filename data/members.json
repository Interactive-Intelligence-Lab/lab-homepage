    {
      "name": { "en": "Hideki Koike", "ja": "小池英樹" },
      "title": { "en": "Cooperative Research Project Director", "ja": "協働研究拠点長" },
      "initials": "HK",
      "color": "#8e44ad",
      "pic": "images/members/koike.jpg",
      "url": "https://www.vogue.cs.titech.ac.jp/koike",
      "affiliation": { "en": "Institute of Science Tokyo, School of Computing, Professor", "ja": "東京科学大学　情報理工学院　教授" },
      "message": {
        "en": "In this cooperative research project, we explore intelligent systems that amplify human creativity and interactions. I hope our work inspires new ideas and collaborations.",
        "ja": "この協働研究拠点では、人間の創造性を代替するのではなく拡張する知的インタラクティブシステムの研究に取り組んでいます。私たちの活動が、新たな発想と協働のきっかけとなれば幸いです。"
      }
    },
    {
      "name": { "en": "Bo Zheng", "ja": "鄭　波" },
      "title": { "en": "Cooperative Research Project Vice Director", "ja": "協働研究副拠点長" },
      "initials": "BZ",
      "color": "#8e44ad",
      "pic": "images/members/zheng.jpg",
      "url": "http://www.bozheng-lab.com/",
      "affiliation": { "en": "Shanda AI Research Tokyo, Research Director", "ja": "Shanda AI Research Tokyo　研究主任" },
      "message": { 
        "en": "We believe interactive intelligence is a critical pathway toward AGI. By advancing AI’s ability to interact with humans and the world—from multimodal perception and memory to higher-level cognition—we aim to develop, through academia–industry collaboration, technologies that create lasting value for society.",
        "ja": "インタラクティブ知能は、AGIへの重要な道筋であると考えています。マルチモーダルな知覚や記憶から高次認知に至るまで、人間および実世界と相互作用するAIの能力を発展させ、産学連携を通じて、社会に持続的な価値をもたらす技術の創出を目指します。" }
    }
